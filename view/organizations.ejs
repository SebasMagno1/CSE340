<%- include("partials/header", { title: "Organizations" }) %>

<main class="container">

    <section class="page-header">
        <h2>Volunteer Organizations</h2>

        <p>
            Explore nonprofit organizations that are making a positive impact
            in communities around the world.
        </p>
    </section>

    <section class="cards">

        <!-- Organization 1 -->
        <article class="card">
            <img src="/images/redcross.webp" alt="American Red Cross">

            <div class="card-content">
                <h3>American Red Cross</h3>

                <p>
                    The American Red Cross helps people affected by disasters,
                    provides emergency assistance, and offers lifesaving training
                    and education.
                </p>

                <a href="https://www.redcross.org" target="_blank" class="btn">
                    Learn More
                </a>
            </div>
        </article>

        <!-- Organization 2 -->
        <article class="card">
            <img src="/images/habitat.webp" alt="Habitat for Humanity">

            <div class="card-content">
                <h3>Habitat for Humanity</h3>

                <p>
                    Habitat for Humanity builds affordable housing and helps
                    families achieve strength, stability, and self-reliance
                    through shelter.
                </p>

                <a href="https://www.habitat.org" target="_blank" class="btn">
                    Learn More
                </a>
            </div>
        </article>

        <!-- Organization 3 -->
        <article class="card">
            <img src="/images/foodbank.webp" alt="Food Bank">

            <div class="card-content">
                <h3>Food Bank</h3>

                <p>
                    Food banks collect and distribute food to people in need,
                    helping reduce hunger in local communities.
                </p>

                <a href="https://www.feedingamerica.org" target="_blank" class="btn">
                    Learn More
                </a>
            </div>
        </article>

        <!-- Organization 4 -->
        <article class="card">
            <img src="/images/volunteer.webp" alt="Volunteer Program">

            <div class="card-content">
                <h3>Community Volunteers</h3>

                <p>
                    Local volunteer groups organize events such as neighborhood
                    cleanups, mentoring programs, and charity drives.
                </p>

                <a href="/projects" class="btn">
                    View Projects
                </a>
            </div>
        </article>

    </section>

</main>

<%- include("partials/footer") %>