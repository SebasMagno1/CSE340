<%- include("partials/header", { title: "Home" }) %>

<main>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h2>Making Our Communities Better Together</h2>

            <p>
                Discover volunteer opportunities, nonprofit organizations,
                and community projects that make a positive impact.
            </p>

            <a href="/projects" class="btn">
                Explore Projects
            </a>
        </div>
    </section>

    <!-- Featured Organizations -->
    <section class="container">

        <h2 class="section-title">Featured Organizations</h2>

        <div class="cards">

            <div class="card">
                <img src="/images/redcross.webp" alt="American Red Cross">
                <h3>American Red Cross</h3>
                <p>
                    Provides emergency assistance, disaster relief, and education.
                </p>
            </div>

            <div class="card">
                <img src="/images/habitat.webp" alt="Habitat for Humanity">
                <h3>Habitat for Humanity</h3>
                <p>
                    Builds affordable housing for families in need.
                </p>
            </div>

            <div class="card">
                <img src="/images/foodbank.webp" alt="Food Bank">
                <h3>Food Bank</h3>
                <p>
                    Helps provide nutritious food to local communities.
                </p>
            </div>

        </div>

    </section>

</main>

<%- include("partials/footer") %>